# Copy this file to ".env" and fill in your Supabase project values.
# The ".env" file is gitignored — never commit real keys.
# Both values are safe for the browser (the anon key is protected by Row-Level Security).

VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Google Apps Script Web App URL that appends enquiries to the Tripcraft_Enquiries
# sheet. See docs/google-apps-script/Code.gs for the script + deploy steps.
VITE_SHEET_WEBAPP_URL=https://script.google.com/macros/s/XXXX/exec
